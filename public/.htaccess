# Deploy bookkeeping written by the GitHub Actions FTP sync — never serve it.
<Files ".ftp-deploy-sync-state.json">
  Require all denied
</Files>

# Baseline security headers. HSTS is safe to send unconditionally because
# .dev is an HSTS-preloaded TLD — the site is HTTPS-only by definition.
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Content-Security-Policy — ran in Report-Only mode first (violations
  # logged to the console, nothing blocked) specifically to verify real
  # traffic through checkout before enforcing; a live browsing pass came
  # back clean, so this now actually enforces.
  #
  # 'unsafe-inline' on script-src/style-src is a deliberate concession, not
  # an oversight: every page carries at least a small inline theme-detection
  # script (and ~20 pages have larger inline logic), and this is a
  # zero-build static-HTML site with no per-request templating to inject a
  # nonce into — a hash-based policy would need updating by hand on every
  # inline-script edit across dozens of files, which fails silently and
  # quietly breaks the page the moment someone forgets. The origin
  # allow-list still blocks the more common real-world attack (loading a
  # malicious script/exfiltrating data to an attacker-controlled domain),
  # just not an inline-script injection via some other vulnerability.
  #
  # Origins: cdn.jsdelivr.net (Bootstrap, Bootstrap Icons, Chart.js),
  # cdnjs.cloudflare.com (highlight.js), js.paystack.co + api.paystack.co +
  # standard.paystack.co + checkout.paystack.com (Paystack SDK/checkout),
  # accounts.google.com (admin Google Sign-In), fonts.googleapis.com +
  # fonts.gstatic.com (Google Fonts, admin only), api.github.com (About
  # page's live GitHub activity feed, browser-side fetch), youtube-nocookie
  # .com + player.vimeo.com (admin-configured hero/demo video embeds — see
  # public/js/content.js; only these two providers are documented as
  # supported, matching README's "YouTube, Vimeo, or direct .mp4/.webm").
  # cdn.jsdelivr.net/cdnjs.cloudflare.com are also in connect-src, not just
  # script/style/font-src — browsers fetch a vendored file's .map sidecar
  # (its own connect, separate from the script/style load) whenever DevTools
  # is open, and that was getting silently blocked without it.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://js.paystack.co https://accounts.google.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; media-src 'self'; connect-src 'self' https://api.github.com https://accounts.google.com https://api.paystack.co https://standard.paystack.co https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com; frame-src 'self' https://www.youtube-nocookie.com https://player.vimeo.com https://accounts.google.com https://checkout.paystack.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

RewriteEngine On

# Canonical host: always redirect www to the bare domain. Without this, the
# site was reachable at both hosts with no redirect, and since the admin
# session cookies aren't domain-scoped, they only apply to whichever host
# was used at login — bouncing between the two looked like getting logged
# out every time.
RewriteCond %{HTTP_HOST} ^www\.princecaleb\.dev$ [NC]
RewriteRule ^(.*)$ https://princecaleb.dev/$1 [R=301,L]

# Maintenance mode: toggled from Admin -> Settings, which creates/deletes
# the .maintenance marker file next to this .htaccess. When present, every
# public-facing request is rewritten internally (no redirect, URL bar and
# request stay the same) to maintenance.php, which sets a real 503 status.
# admin, api, uploads, and the static assets the maintenance page itself
# needs stay reachable — so the admin can always log in and switch it off.
RewriteCond %{DOCUMENT_ROOT}/.maintenance -f
RewriteCond %{REQUEST_URI} !^/admin
RewriteCond %{REQUEST_URI} !^/api
RewriteCond %{REQUEST_URI} !^/uploads
RewriteCond %{REQUEST_URI} !^/css
RewriteCond %{REQUEST_URI} !^/js
RewriteCond %{REQUEST_URI} !^/icons
RewriteCond %{REQUEST_URI} !^/manifest\.json$
RewriteCond %{REQUEST_URI} !^/sw\.js$
RewriteCond %{REQUEST_URI} !^/maintenance\.(html|php)$
RewriteRule ^ /maintenance.php [L]

# Server-side social share meta: the two dynamic content pages go through
# og-render.php, which injects per-item og:image/title/description into the
# real HTML template so crawlers (which don't run JS) preview each blog post
# and project correctly. Placed after the maintenance block so maintenance
# mode still wins. Fail-open — og-render.php serves the template unchanged if
# anything goes wrong, so these pages can't break. QSA keeps ?slug=.
RewriteRule ^project\.html$ og-render.php?_page=project [L,QSA]
RewriteRule ^archive-post\.html$ og-render.php?_page=archive [L,QSA]

# Serve real files/directories as-is; route everything else under /api/ through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/ index.php [L]

# Short links (/s/{code}, see ShortLinkController) also route through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^s/ index.php [L]

# Branded 404 page instead of the host's default error page
ErrorDocument 404 /404.html

# The host's default cache-control for CSS/JS is 7 days, which is too long
# for a site with no cache-busting (no build step, no hashed filenames —
# public/*.html link straight to /css/app.css, /js/*.js). A change deployed
# today wouldn't reach a returning visitor's browser for up to a week.
# Shortening it to 1 hour keeps real caching benefit for same-session
# navigation without silently hiding fixes/features for days.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 hour"
  ExpiresByType application/javascript "access plus 1 hour"
  ExpiresByType text/javascript "access plus 1 hour"
</IfModule>

# Vendored libraries (see /js/vendor/.htaccess) get a long cache instead —
# they live in versioned directories and never change in place.

# Compress text assets. Matters most for the ~720KB Three.js module pair
# (~170KB gzipped); harmless no-op if the host already compresses globally.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
