# Deploy bookkeeping written by the GitHub Actions FTP sync — never serve it.
<Files ".ftp-deploy-sync-state.json">
  Require all denied
</Files>

RewriteEngine On

# Canonical host: always redirect www to the bare domain. Without this, the
# site was reachable at both hosts with no redirect, and since the admin
# session cookies aren't domain-scoped, they only apply to whichever host
# was used at login — bouncing between the two looked like getting logged
# out every time.
RewriteCond %{HTTP_HOST} ^www\.princecaleb\.dev$ [NC]
RewriteRule ^(.*)$ https://princecaleb.dev/$1 [R=301,L]

# Maintenance mode: toggled from Admin -> Settings, which creates/deletes
# the .maintenance marker file next to this .htaccess. When present, every
# public-facing request is rewritten internally (no redirect, URL bar and
# request stay the same) to maintenance.php, which sets a real 503 status.
# admin, api, uploads, and the static assets the maintenance page itself
# needs stay reachable — so the admin can always log in and switch it off.
RewriteCond %{DOCUMENT_ROOT}/.maintenance -f
RewriteCond %{REQUEST_URI} !^/admin
RewriteCond %{REQUEST_URI} !^/api
RewriteCond %{REQUEST_URI} !^/uploads
RewriteCond %{REQUEST_URI} !^/css
RewriteCond %{REQUEST_URI} !^/js
RewriteCond %{REQUEST_URI} !^/icons
RewriteCond %{REQUEST_URI} !^/manifest\.json$
RewriteCond %{REQUEST_URI} !^/sw\.js$
RewriteCond %{REQUEST_URI} !^/maintenance\.(html|php)$
RewriteRule ^ /maintenance.php [L]

# Serve real files/directories as-is; route everything else under /api/ through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/ index.php [L]

# Short links (/s/{code}, see ShortLinkController) also route through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^s/ index.php [L]

# Branded 404 page instead of the host's default error page
ErrorDocument 404 /404.html

# The host's default cache-control for CSS/JS is 7 days, which is too long
# for a site with no cache-busting (no build step, no hashed filenames —
# public/*.html link straight to /css/app.css, /js/*.js). A change deployed
# today wouldn't reach a returning visitor's browser for up to a week.
# Shortening it to 1 hour keeps real caching benefit for same-session
# navigation without silently hiding fixes/features for days.
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 hour"
  ExpiresByType application/javascript "access plus 1 hour"
  ExpiresByType text/javascript "access plus 1 hour"
</IfModule>
