# Copy to .env and adjust. Everything has a sensible default for local dev.

# APP_ENV=development
# JWT_SECRET=change-me-to-a-long-random-string

# Optional: only needed for the secondary AI assistant widget.
# Without it, the widget falls back to simple keyword matching against your projects.
# GEMINI_API_KEY=

# Optional: Slack incoming webhook URL for instant inquiry notifications.
# Without it, process_webhooks.php just marks queued notifications as sent (no-op).
# SLACK_WEBHOOK_URL=

# Optional: enables auto-migration on deploy. Set this to a long random string
# AND add the same value as a GitHub Actions secret named DEPLOY_MIGRATE_TOKEN.
# After each deploy, the workflow calls public/deploy-migrate.php with this
# token to run database/migrate.php (idempotent). Leave unset to keep running
# migrations manually — the endpoint fails closed (503) when this is empty.
# DEPLOY_MIGRATE_TOKEN=
